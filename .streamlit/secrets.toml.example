# .streamlit/secrets.toml — Streamlit Cloud secrets
# Paste this into: App dashboard → Settings → Secrets
#
# ── API Key ──────────────────────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."

# ── Authentication ───────────────────────────────────────
# Passwords must be bcrypt hashes.
# Generate one:  python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"

[auth]

[auth.cookie]
name = "docrag_auth"
key = "change-this-to-a-random-secret-string"
expiry_days = 30

[auth.credentials.usernames.admin]
email = "admin@example.com"
name = "Admin"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"

[auth.credentials.usernames.user]
email = "user@example.com"
name = "User"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
